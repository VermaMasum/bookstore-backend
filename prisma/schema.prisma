generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password         String
  phone            String?
  role             String    @default("ADMIN")
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
}

model Publisher {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  books     Book[]
}

model Company {
  id             Int             @id @default(autoincrement())
  name           String
  contact        String?
  email          String?
  address        String?
  creditLimit    Decimal?        @db.Decimal(10, 2)
  createdAt      DateTime        @default(now())
  purchaseOrders PurchaseOrder[]
  vendorOrders   VendorOrder[]
  payments       Payment[]
}

model School {
  id           Int           @id @default(autoincrement())
  name         String
  address      String?
  contact      String?
  email        String?
  classLevels  String?
  createdAt    DateTime      @default(now())
  bookSets     BookSet[]
  payments     Payment[]
  schoolOrders SchoolOrder[]
}

model Book {
  id          Int                 @id @default(autoincrement())
  title       String
  isbn        String?             @unique
  author      String?
  publisherId Int
  category    String?
  board       String?
  level       String?
  costPrice   Decimal             @db.Decimal(10, 2)
  createdAt   DateTime            @default(now())
  publisher   Publisher           @relation(fields: [publisherId], references: [id])
  setItems    BookSetItem[]
  inventory   Inventory?
  poItems     PurchaseOrderItem[]
  schoolItems SchoolOrderItem[]
  vendorItems VendorOrderItem[]
}

model Inventory {
  id          Int      @id @default(autoincrement())
  bookId      Int      @unique
  quantity    Int      @default(0)
  lastUpdated DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id])
}

model PurchaseOrder {
  id        Int                 @id @default(autoincrement())
  companyId Int
  orderDate DateTime            @default(now())
  status    PurchaseOrderStatus @default(PENDING)
  notes     String?
  company   Company             @relation(fields: [companyId], references: [id])
  items     PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  bookId          Int
  quantity        Int
  unitCost        Decimal       @db.Decimal(10, 2)
  book            Book          @relation(fields: [bookId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model VendorOrder {
  id        Int               @id @default(autoincrement())
  companyId Int
  orderDate DateTime          @default(now())
  status    VendorOrderStatus @default(PENDING)
  notes     String?
  company   Company           @relation(fields: [companyId], references: [id])
  items     VendorOrderItem[]
  payments  Payment[]
  invoice   Invoice?
}

model VendorOrderItem {
  id            Int         @id @default(autoincrement())
  vendorOrderId Int
  bookId        Int
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  book          Book        @relation(fields: [bookId], references: [id])
  vendorOrder   VendorOrder @relation(fields: [vendorOrderId], references: [id])
}

model BookSet {
  id           Int           @id @default(autoincrement())
  name         String
  schoolId     Int
  className    String
  sessionYear  String
  board        String?
  level        String?
  totalPrice   Decimal?      @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  school       School        @relation(fields: [schoolId], references: [id])
  items        BookSetItem[]
  schoolOrders SchoolOrder[]
}

model BookSetItem {
  id       Int     @id @default(autoincrement())
  setId    Int
  bookId   Int
  quantity Int     @default(1)
  book     Book    @relation(fields: [bookId], references: [id])
  bookSet  BookSet @relation(fields: [setId], references: [id])
}

model SchoolOrder {
  id            Int               @id @default(autoincrement())
  schoolId      Int
  setId         Int?
  userId        Int?
  orderDate     DateTime          @default(now())
  status        SchoolOrderStatus @default(PENDING)
  childName     String?
  guardianName  String?
  notes         String?
  payments      Payment[]
  school        School            @relation(fields: [schoolId], references: [id])
  bookSet       BookSet?          @relation(fields: [setId], references: [id])
  items         SchoolOrderItem[]
  invoice       Invoice?
}

model SchoolOrderItem {
  id            Int         @id @default(autoincrement())
  schoolOrderId Int
  bookId        Int
  qtyOrdered    Int
  qtyDelivered  Int         @default(0)
  unitPrice     Decimal     @db.Decimal(10, 2)
  book          Book        @relation(fields: [bookId], references: [id])
  schoolOrder   SchoolOrder @relation(fields: [schoolOrderId], references: [id])
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderType     OrderType
  vendorOrderId Int?
  schoolOrderId Int?
  companyId     Int?
  schoolId      Int?
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  notes         String?
  company       Company?      @relation(fields: [companyId], references: [id])
  school        School?       @relation(fields: [schoolId], references: [id])
  schoolOrder   SchoolOrder?  @relation(fields: [schoolOrderId], references: [id])
  vendorOrder   VendorOrder?  @relation(fields: [vendorOrderId], references: [id])
}

model ShopSettings {
  id            Int     @id @default(autoincrement())
  shopName      String  @default("My Bookstore")
  address       String  @default("")
  city          String  @default("")
  state         String  @default("")
  pincode       String  @default("")
  gstin         String  @default("")
  phone         String  @default("")
  email         String  @default("")
  bankName      String  @default("")
  accountNo     String  @default("")
  ifscCode      String  @default("")
  lastInvoiceNo Int     @default(0)
}

model DailyReconciliation {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique @db.Date
  openingStock   Int
  closingStock   Int
  salesB2B       Decimal  @db.Decimal(10, 2)
  salesB2C       Decimal  @db.Decimal(10, 2)
  purchasesTotal Decimal  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime @default(now())
}

model Invoice {
  id             Int           @id @default(autoincrement())
  invoiceNumber  String        @unique
  orderType      OrderType
  vendorOrderId  Int?          @unique
  schoolOrderId  Int?          @unique
  buyerName      String
  buyerAddress   String        @default("")
  buyerGstin     String        @default("")
  buyerPhone     String        @default("")
  buyerEmail     String        @default("")
  subtotal       Decimal       @db.Decimal(10, 2)
  discountTotal  Decimal       @db.Decimal(10, 2)
  gstRate        Float         @default(0)
  supplyType     String        @default("INTRA")
  taxAmount      Decimal       @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  vendorOrder    VendorOrder?  @relation(fields: [vendorOrderId], references: [id])
  schoolOrder    SchoolOrder?  @relation(fields: [schoolOrderId], references: [id])
  items          InvoiceItem[]
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  bookTitle   String
  bookClass   String  @default("")
  publisher   String  @default("")
  isbn        String  @default("")
  hsnCode     String  @default("4901")
  qty         Int
  unitPrice   Decimal @db.Decimal(10, 2)
  discountPct Float   @default(0)
  amount      Decimal @db.Decimal(10, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

enum VendorOrderStatus {
  PENDING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum SchoolOrderStatus {
  PENDING
  PARTIAL
  DELIVERED
  CANCELLED
}

enum OrderType {
  B2B
  B2C
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
}
